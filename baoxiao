        const advanceReimbursement = document.getElementById('advanceReimbursement');
        const executionReimbursement = document.getElementById('executionReimbursement');
        const executionOrder = document.getElementById('executionOrder');
        const payee = document.getElementById('payee');
        const reimbursementCode = document.getElementById('reimbursementCode');

        // 初始化
        updateReimbursementType();

        // 报销类型切换事件
        reimbursementTypeRadios.forEach(radio => {
            radio.addEventListener('change', updateReimbursementType);
        });

        function updateReimbursementType() {
            const selectedType = document.querySelector('input[name="reimbursementType"]:checked').value;
            
            if (selectedType === 'personal') {
                // 个人报销：隐藏执行单相关信息
                executionInfo.classList.add('hidden');
                advanceReimbursement.classList.add('hidden');
                executionReimbursement.classList.add('hidden');
                executionOrder.disabled = true;
                payee.disabled = false;
            } else if (selectedType === 'advance') {
                // 个人预支报销：显示所有字段
                executionInfo.classList.remove('hidden');
                advanceReimbursement.classList.remove('hidden');
                executionReimbursement.classList.remove('hidden');
                executionOrder.disabled = false;
                payee.disabled = true; // 预支单锁定收款人
            } else if (selectedType === 'execution') {
                // 执行单报销：只显示执行单报销部分
                executionInfo.classList.remove('hidden');
                advanceReimbursement.classList.add('hidden');
                executionReimbursement.classList.remove('hidden');
                executionOrder.disabled = false;
                payee.disabled = false;
            }
        }

        // 执行单选择后的信息更新
        document.getElementById('executionOrder').addEventListener('change', function() {
            const selectedValue = this.value;
            if (selectedValue) {
                // 这里可以根据选择的执行单加载相应的数据
                document.getElementById('executionInfo').classList.remove('hidden');
                // 生成报销单编号
                const date = new Date();
                const dateStr = date.getFullYear() + padZero(date.getMonth() + 1) + padZero(date.getDate());
                const randomNum = Math.floor(Math.random() * 1000).toString().padStart(3, '0');
                reimbursementCode.value = 'RB' + dateStr + randomNum;
            } else {
                document.getElementById('executionInfo').classList.add('hidden');
            }
        });

        // 辅助函数：补零
        function padZero(num) {
            return num.toString().padStart(2, '0');
        }

        // 模拟发票上传功能
        const dropZone = document.querySelector('.border-dashed');
        dropZone.addEventListener('dragover', function(e) {
            e.preventDefault();
            this.classList.add('border-primary');
        });
        dropZone.addEventListener('dragleave', function() {
            this.classList.remove('border-primary');
        });
        dropZone.addEventListener('drop', function(e) {
            e.preventDefault();
            this.classList.remove('border-primary');
            // 这里可以处理文件上传逻辑
            alert('文件上传功能已触发');
        });

        // 模拟提交审批
        document.querySelector('button:contains("提交审批")').addEventListener('click', function() {
            alert('报销单已提交审批');
        });
    </script>
</body>
</html>
